# ANSIBLE MANAGED — 9router AI gateway (ansible-ai/deploy-9router.yml). Edit the
# playbook/template, not this file on the host. Internal-only: both ports bind 127.0.0.1.
services:
  9router:
    image: decolua/9router:latest
    container_name: 9router
    restart: always
    ports:
      - "127.0.0.1:{{ ninerouter_port }}:20128"
    volumes:
      - 9router-data:/app/data
    env_file:
      - {{ ninerouter_dir }}/.env
    environment:
      DATA_DIR: /app/data
      PORT: "20128"
      HOSTNAME: "0.0.0.0"
      NODE_ENV: production
      HEADROOM_URL: http://headroom:8787
    depends_on:
      - headroom

  headroom:
    image: ghcr.io/chopratejas/headroom:latest
    container_name: headroom
    restart: always
    ports:
      - "127.0.0.1:{{ ninerouter_headroom_port }}:8787"

volumes:
  9router-data:
    name: 9router-data
