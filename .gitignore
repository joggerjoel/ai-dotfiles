# Secrets - never commit
.env
*.env.local
.env.*
!.env.example

# Real fleet inventory (IPs, jump hosts, usernames) — copy from inventory.example.yml
ansible-ai/inventory.local.yml

# Live/personal config that can accumulate inline secrets (CC permission allowlist, etc.)
/settings.json
# MCP profiles hold live tokens (e.g. SUPABASE_ACCESS_TOKEN) — keep the README, ignore the JSON
profiles/mcp/*.json

# Machine-specific overrides (personal config)
.local/

# Local tool state (generated per-machine, not versioned)
.serena/

# OS files
.DS_Store
Thumbs.db

# Backups
backups/
backup/
